/*
  Content-Security-Policy: default-src 'self'; script-src 'self' https://unpkg.com; style-src 'self' 'unsafe-inline' https://unpkg.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://bwrmaps.com https://www.bwrmaps.com https://bwr-worker.ciril8596.workers.dev https://api.openrouteservice.org https://router.project-osrm.org https://nominatim.openstreetmap.org https://api.open-meteo.com https://api.opentopodata.org https://api.open-elevation.com https://*.tile.openstreetmap.org https://*.tile.opentopomap.org https://data.geopf.fr https://fonts.googleapis.com https://fonts.gstatic.com https://unpkg.com https://overpass-api.de https://ntfy.sh; worker-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), camera=(self)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# HTML pages must always revalidate so new deploys (changelog, content) show up
# immediately instead of being held by the Cloudflare edge / browser cache.
/*.html
  Cache-Control: no-cache

# Static media (images, icons, favicon) is content-stable and safe to cache for
# 30 days — the browser stops re-fetching it on every visit. Deliberately NOT
# applied to .js/.css: those filenames are not content-hashed, so they must keep
# revalidating (the service worker is network-first for app files) or a deploy
# would be held back behind a stale cache.
/*.png
  Cache-Control: public, max-age=2592000
/*.jpg
  Cache-Control: public, max-age=2592000
/*.jpeg
  Cache-Control: public, max-age=2592000
/*.webp
  Cache-Control: public, max-age=2592000
/*.svg
  Cache-Control: public, max-age=2592000
/*.ico
  Cache-Control: public, max-age=2592000
