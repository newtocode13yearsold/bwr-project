{
  "name": "bwr-worker",
  "main": "worker.js",
  "compatibility_date": "2024-01-01",
  "assets": { "directory": "./public", "run_worker_first": false },
  "workers_dev": true,
  "routes": [
    { "pattern": "bwrmaps.com", "custom_domain": true },
    { "pattern": "www.bwrmaps.com", "custom_domain": true }
  ],
  "kv_namespaces": [
    {
      "binding": "BWR_KV",
      "id": "da878110f87d4dc6975a6bf3e44cd7ed"
    }
  ],
  "ai": {
    "binding": "AI"
  }
}
